<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AppProyectos</title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    
    <script src="https://unpkg.com/htmx.org@1.9.11"></script>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: '#4f46e5', // Un tono índigo muy moderno
                        brandHover: '#4338ca'
                    }
                }
            }
        }
    </script>
</head>
<body class="bg-gray-50 text-gray-800 font-sans antialiased">

    <nav class="bg-white shadow-sm border-b border-gray-100 mb-8">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <a asp-controller="Proyectos" asp-action="Index" class="text-2xl font-black text-brand tracking-tight">
                        Task<span class="text-gray-800">Flow</span>
                    </a>
                </div>
                
                <div class="flex items-center space-x-4">
                    @if (User.Identity!.IsAuthenticated)
                    {
                        <span class="text-sm text-gray-500">Hola, <span class="font-bold text-gray-900">@User.Identity.Name</span></span>
                        <a asp-controller="Cuenta" asp-action="Salir" class="px-4 py-2 text-sm font-medium text-red-600 bg-red-50 hover:bg-red-100 rounded-lg transition-colors">
                            Cerrar Sesión
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Cuenta" asp-action="Login" class="px-4 py-2 text-sm font-medium text-white bg-brand hover:bg-brandHover rounded-lg shadow-sm transition-colors">
                            Iniciar Sesión
                        </a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
        @RenderBody()
    </main>

</body>
</html>