@{
    ViewData["Title"] = "Nueva Tarea";
}

<div class="max-w-3xl mx-auto mt-10">
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="bg-green-600 p-6 text-white text-center">
            <h4 class="text-xl font-bold">Asignar Nueva Tarea</h4>
            <p class="text-green-50 text-sm mt-1">Asigna actividades a los miembros de tu equipo.</p>
        </div>

        <form asp-action="Crear" method="post" class="p-8 space-y-6">
            <input type="hidden" name="Proyectoid" value="@ViewBag.ProyectoId" />

            <div>
                <label for="Titulo" class="block text-sm font-semibold text-gray-700 mb-1">Título de la Tarea</label>
                <input type="text" id="Titulo" name="Titulo" required 
                    class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-green-500 focus:border-green-500 outline-none transition-all">
            </div>

            <div>
                <label for="Descripcion" class="block text-sm font-semibold text-gray-700 mb-1">Descripción Detallada</label>
                <textarea id="Descripcion" name="Descripcion" rows="3" required
                    class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-green-500 focus:border-green-500 outline-none transition-all"></textarea>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label for="Asignadoa" class="block text-sm font-semibold text-gray-700 mb-1">Asignar a:</label>
                    <select id="Asignadoa" name="Asignadoa" asp-items="ViewBag.Usuarios" required
                        class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-green-500 focus:border-green-500 outline-none transition-all bg-white">
                        <option value="">-- Selecciona un usuario --</option>
                    </select>
                </div>
                <div>
                    <label for="FechaVencimiento" class="block text-sm font-semibold text-gray-700 mb-1">Fecha Límite</label>
                    <input type="date" id="FechaVencimiento" name="FechaVencimiento" required 
                        class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-green-500 focus:border-green-500 outline-none transition-all">
                </div>
            </div>

            <div class="flex items-center justify-between pt-4 border-t border-gray-50">
                <a asp-action="Index" asp-route-id="@ViewBag.ProyectoId" class="text-sm font-semibold text-gray-500 hover:text-gray-700 transition-colors">
                    Cancelar
                </a>
                <button type="submit" class="px-8 py-3 bg-green-600 hover:bg-green-700 text-white font-bold rounded-xl shadow-md transition-all">
                    Guardar Tarea
                </button>
            </div>
        </form>
    </div>
</div>